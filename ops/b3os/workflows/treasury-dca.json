{
  "name": "LifePool — Treasury DCA",
  "description": "Monthly premium DCA into grid/stake sleeves using live ops signal.",
  "trigger": {
    "type": "cronjob",
    "schedule": "0 9 1 * *"
  },
  "nodes": [
    {
      "id": "signal",
      "action": "http-request",
      "config": {
        "url": "{{env.LIFEPOOL_URL}}/api/ops/signal",
        "method": "GET"
      }
    },
    {
      "id": "read-nav",
      "action": "evm-read",
      "config": {
        "contract": "{{env.TREASURY_VAULT_ADDRESS}}",
        "function": "treasuryNav",
        "chainId": 84532
      }
    },
    {
      "id": "policy-balance",
      "action": "if",
      "config": {
        "condition": "{{read-nav.premiumBal}} >= {{signal.suggestedDcaUsdc * 1e6}}"
      }
    },
    {
      "id": "set-grid-bps",
      "action": "evm-write",
      "connector": "wallet",
      "config": {
        "contract": "{{env.TREASURY_VAULT_ADDRESS}}",
        "function": "setGridAllocationBps",
        "args": ["{{signal.gridAllocationBps}}"],
        "chainId": 84532
      }
    },
    {
      "id": "execute-dca",
      "action": "evm-write",
      "connector": "wallet",
      "config": {
        "contract": "{{env.TREASURY_VAULT_ADDRESS}}",
        "function": "executeDca",
        "args": ["{{signal.suggestedDcaUsdc * 1e6}}", "{{signal.gridAllocationBps}}"],
        "chainId": 84532
      }
    }
  ]
}
