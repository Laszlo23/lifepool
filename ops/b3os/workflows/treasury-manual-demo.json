{
  "name": "LifePool — Manual Treasury Demo",
  "description": "Run DCA + harvest immediately for demos (webhook trigger). Import this for instant B3OS dashboard activity.",
  "trigger": {
    "type": "webhook",
    "description": "POST to trigger — use before investor demo"
  },
  "nodes": [
    {
      "id": "signal",
      "action": "http-request",
      "config": {
        "url": "{{env.LIFEPOOL_URL}}/api/ops/signal",
        "method": "GET"
      }
    },
    {
      "id": "read-nav",
      "action": "evm-read",
      "config": {
        "contract": "{{env.TREASURY_VAULT_ADDRESS}}",
        "function": "treasuryNav",
        "chainId": 84532
      }
    },
    {
      "id": "set-grid-bps",
      "action": "evm-write",
      "connector": "wallet",
      "config": {
        "contract": "{{env.TREASURY_VAULT_ADDRESS}}",
        "function": "setGridAllocationBps",
        "args": ["{{signal.gridAllocationBps}}"],
        "chainId": 84532
      }
    },
    {
      "id": "execute-dca",
      "action": "evm-write",
      "connector": "wallet",
      "config": {
        "contract": "{{env.TREASURY_VAULT_ADDRESS}}",
        "function": "executeDca",
        "args": ["{{signal.suggestedDcaUsdc * 1e6}}", "{{signal.gridAllocationBps}}"],
        "chainId": 84532
      }
    },
    {
      "id": "harvest",
      "action": "evm-write",
      "connector": "wallet",
      "config": {
        "contract": "{{env.TREASURY_VAULT_ADDRESS}}",
        "function": "harvestToRewards",
        "args": ["{{signal.suggestedHarvestLifeEur * 1e18}}"],
        "chainId": 84532
      }
    },
    {
      "id": "read-treasury",
      "action": "http-request",
      "config": {
        "url": "{{env.LIFEPOOL_URL}}/api/ops/treasury",
        "method": "GET"
      }
    }
  ]
}
