# Base Sepolia — copy to .env (never commit .env)

# Public RPC (frontend + API). Prefer Alchemy/Infura for investor demos.
VITE_CHAIN_ID=84532
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Production URL (4EVERLAND)
VITE_APP_URL=https://lifepool-e17s.ipfs.4everland.app

# Optional
VITE_B3OS_OPERATOR_ADDRESS=0xaaf620ee9e2a805323BF7363992E33e4412be3FB
VITE_WALLETCONNECT_PROJECT_ID=

# Gasless txs (Coinbase / Base Smart Wallet) — see docs/PAYMASTER.md
VITE_PAYMASTER_ENABLED=true
# Override when static host cannot serve /api (e.g. IPFS → point at Vercel proxy)
# VITE_PAYMASTER_PROXY_URL=https://your-app.vercel.app/api/paymaster

# Server-side only — CDP Paymaster & Bundler endpoint (never VITE_ prefix)
CDP_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base-sepolia/YOUR_CDP_API_KEY
# Comma-separated origins allowed to call /api/paymaster (defaults include VITE_APP_URL + localhost)
PAYMASTER_ALLOWED_ORIGINS=

# Server / CI only — set in Vercel Secrets + GitHub Actions, NOT as VITE_
KEEPER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
B3OS_OPERATOR_ADDRESS=0xaaf620ee9e2a805323BF7363992E33e4412be3FB
EUR_USD_RATE=0.92
ETHERSCAN_API_KEY=
